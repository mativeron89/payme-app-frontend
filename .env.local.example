# T7 — conexión al backend real local.
# Copiar a `.env.local` (que NO se versiona) para trabajar contra el backend.
#
#   cp .env.local.example .env.local
#
# Con esto el front deja de usar la demo y habla con payme-app-backend.

VITE_MOCK=0
VITE_API_URL=http://localhost:3000

# G-01: el contrato no expone la lista de restaurantes, pero POST /mesas exige
# un restaurant_id existente y activo. Acá va el uuid de la fila sembrada en la
# base local (el script de arranque lo imprime al crearla).
VITE_RESTAURANT_ID=
VITE_RESTAURANT_NAME=La Parolaccia

# La clave PUBLICABLE de Stripe NO se pone acá: el front la pide a
# GET /api/config, que la sirve desde el .env del backend. La clave SECRETA
# vive únicamente en el backend.
